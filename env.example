# Notification channel: telegram | file
NOTIFIER_TYPE=telegram

# Telegram bot token from @BotFather (required when NOTIFIER_TYPE=telegram)
TG_BOT_TOKEN=

# Telegram chat/channel ID where notifications are sent (required when NOTIFIER_TYPE=telegram)
TG_CHAT_ID=

# Path to file with wallets list
ADDRESSES_FILE=addresses.txt

# Path to snapshot file with last known balances
SNAPSHOT_FILE=balances_snapshot.json

# Monitor interval: supports Go duration format (e.g. 1h, 30m, 10s) or seconds as number
POLL_INTERVAL=1h

# Max number of concurrent address checks per run
MAX_CONCURRENT_CHECKS=20

# BTC API host
BTC_API_HOST=

# TRX full node gRPC host
TRX_GRPC_HOST=
